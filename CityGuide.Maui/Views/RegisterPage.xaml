<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CityGuide.Maui.Views.RegisterPage"
             Title="RegisterPage"
             BackgroundColor="#F8F9FA">

    <ScrollView>

        <!-- Tüm içerik dikey, dikeyde ortalı -->
        <VerticalStackLayout Padding="20"
                             Spacing="24"
                             VerticalOptions="Center">

            <!-- MARKA BAŞLIĞI -->
            <VerticalStackLayout Spacing="4">

                <Label Text="Milano City Guide"
           TextColor="#0D47A1"
           FontSize="30"
           FontAttributes="Bold"
           HorizontalOptions="Center"
           HorizontalTextAlignment="Center" />

                <Label Text="Milano'yu Keşfetmeye Hazır mısınız?"
           TextColor="#455A64"
           FontSize="16"
           HorizontalOptions="Center"
           HorizontalTextAlignment="Center" />

            </VerticalStackLayout>

            <!-- KAYIT KARTI -->
            <Border BackgroundColor="#FFFFFF"
        Stroke="#C3C6D4"
        StrokeThickness="1"
        Padding="24"
        StrokeShape="RoundRectangle 12">

                <VerticalStackLayout Spacing="16">

                    <!-- === AD SOYAD ALANI === -->
                    <VerticalStackLayout Spacing="8">

                        <!-- Etiket: label-md 14/500 -->
                        <Label Text="Ad Soyad"
                   FontSize="14"
                   TextColor="#434652" />

                        <!-- Giriş kutusu: ikon + Entry yan yana -->
                        <Border Stroke="#C3C6D4"
                    StrokeThickness="1"
                    Padding="12,0"
                    StrokeShape="RoundRectangle 8">

                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">

                                <!-- Sol: ikon -->
                                <Label Grid.Column="0"
                           Text="👤"
                           FontSize="18"
                           VerticalOptions="Center" />

                                <!-- Sağ: metin girişi -->
                                <Entry Grid.Column="1"
                                       x:Name="FullNameEntry"
                           Placeholder="Adınızı ve soyadınızı girin"
                           FontSize="16"
                           BackgroundColor="Transparent" />

                            </Grid>

                        </Border>

                    </VerticalStackLayout>

                    <!-- === E-POSTA ALANI === -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="E-posta Adresi"
           FontSize="14"
           TextColor="#434652" />
                        <Border Stroke="#C3C6D4"
            StrokeThickness="1"
            Padding="12,0"
            StrokeShape="RoundRectangle 8">
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                                <Label Grid.Column="0"
                   Text="✉️"
                   FontSize="18"
                   VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                        x:Name="EmailEntry"
                   Placeholder="ornek@eposta.com"
                   Keyboard="Email"
                   FontSize="16"
                   BackgroundColor="Transparent" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- === ŞİFRE ALANI === -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Şifre"
           FontSize="14"
           TextColor="#434652" />
                        <Border Stroke="#C3C6D4"
            StrokeThickness="1"
            Padding="12,0"
            StrokeShape="RoundRectangle 8">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">

                                <!-- Sol: kilit ikonu -->
                                <Label Grid.Column="0"
           Text="🔒"
           FontSize="18"
           VerticalOptions="Center" />

                                <!-- Orta: şifre girişi -->
                                <Entry Grid.Column="1"
           x:Name="PasswordEntry"
           Placeholder="Bir şifre oluşturun"
           IsPassword="True"
           FontSize="16"
           BackgroundColor="Transparent" />

                                <!-- Sağ: göster/gizle ikonu -->
                                <Label Grid.Column="2"
           x:Name="PasswordToggleIcon"
           Text="🙈"
           FontSize="18"
           VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTogglePasswordVisibility" />
                                    </Label.GestureRecognizers>
                                </Label>

                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- === ŞİFRE TEKRAR ALANI === -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Şifre Tekrar"
           FontSize="14"
           TextColor="#434652" />
                        <Border Stroke="#C3C6D4"
            StrokeThickness="1"
            Padding="12,0"
            StrokeShape="RoundRectangle 8">
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                                <Label Grid.Column="0"
                   Text="🔒"
                   FontSize="18"
                   VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                        x:Name="ConfirmPasswordEntry"
                   Placeholder="Şifrenizi tekrar girin"
                   IsPassword="True"
                   FontSize="16"
                   BackgroundColor="Transparent" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- === ŞARTLAR ONAY KUTUSU === -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">

                        <!-- Onay kutusu -->
                        <CheckBox Grid.Column="0"
              x:Name="TermsCheckBox"
              Color="#0D47A1"
              VerticalOptions="Start" />

                        <!-- Metin (vurgulu + tıklanabilir kelimelerle) -->
                        <Label Grid.Column="1"
           FontSize="14"
           TextColor="#434652"
           VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Milano Şehir Rehberi'nin " />
                                    <Span Text="Şartlar ve Koşulları"
                      TextColor="#0D47A1"
                      FontAttributes="Bold"
                      TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTermsTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                    <Span Text="'nı ve " />
                                    <Span Text="Gizlilik Politikası"
                      TextColor="#0D47A1"
                      FontAttributes="Bold" />
                                    <Span Text="'nı kabul ediyorum." />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                    </Grid>
                    <!-- HESAP OLUŞTUR BUTONU -->
                    <Button Text="Hesap Oluştur"
        x:Name="RegisterButton"
        Clicked="OnRegisterClicked"
        BackgroundColor="#0D47A1"
        TextColor="#FFFFFF"
        FontSize="14"
        FontAttributes="Bold"
        HeightRequest="52"
        CornerRadius="8"
        Margin="0,8,0,0" />

                    <!-- ALT EYLEM: Giriş Yap -->
                    <VerticalStackLayout Spacing="12" Margin="0,8,0,0">

                        <!-- İnce ayraç çizgisi -->
                        <BoxView HeightRequest="1" Color="#C3C6D4" />

                        <!-- "Zaten hesabın var mı? Giriş Yap" -->
                        <Label HorizontalOptions="Center"
           HorizontalTextAlignment="Center"
           FontSize="16"
           TextColor="#434652">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Zaten hesabın var mı? " />
                                    <Span Text="Giriş Yap"
                      TextColor="#0D47A1"
                      FontAttributes="Bold"
                      TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSignInTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                    </VerticalStackLayout>

                    <!-- FOOTER -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                        <Label Text="Destek"
           FontSize="12"
           TextColor="#455A64">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSupportTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="•" FontSize="12" TextColor="#C3C6D4" />
                        <Label Text="Dil: Türkçe"
           FontSize="12"
           TextColor="#455A64" />
                    </HorizontalStackLayout>


                </VerticalStackLayout>
                

            </Border>
            
            


            <!-- FOOTER -->
            <BoxView HeightRequest="40" Color="#455A64" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
