<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CityGuide.Maui.Views.WelcomePage"
             Title="WelcomePage">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0"
              HeightRequest="64"
              ColumnDefinitions="*, Auto"
              Padding="20,0"
              BackgroundColor="#F8F9FA">

            <Label Grid.Column="0"
                   Text="Milano Şehir Rehberi"
                   TextColor="#0D47A1"
                   FontSize="22"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Start" />

            <Label Grid.Column="1"
                   Text="🌐"
                   FontSize="22"
                   VerticalOptions="Center"
                   HorizontalOptions="End" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">
                <BoxView HeightRequest="400" Color="#D4AF37" />
                <BoxView HeightRequest="250" Color="#00796B" />
                <BoxView HeightRequest="350" Color="#455A64" />
                <BoxView HeightRequest="120" Color="#191C1D" />
                <!-- ============ FOOTER ============ -->
                <VerticalStackLayout Padding="20,24" Spacing="16">

                    <BoxView HeightRequest="1"
                        Color="#C3C6D4"
                        HorizontalOptions="Fill" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                            Text="2026 Milano Şehir Rehberi. Tüm hakları saklıdır."
                            TextColor="#737783"
                            FontSize="12"
                            VerticalOptions="Center" 
                        />

                        <HorizontalStackLayout Grid.Column="1" Spacing="24">
                            <Label Text="Explore" TextColor="#737783" FontSize="12" />
                            <Label Text="Concierge" TextColor="#737783" FontSize="12" />
                            <Label Text="Stay" TextColor="#737783" FontSize="12" />
                        </HorizontalStackLayout>

                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>


